{
  "description": "claude-transcript-analyzer: collect Skills/Subagents usage events",
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$(command -v python3 || command -v python)\" ${CLAUDE_PLUGIN_ROOT}/hooks/record_skill.py"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$(command -v python3 || command -v python)\" ${CLAUDE_PLUGIN_ROOT}/hooks/record_subagent.py"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$(command -v python3 || command -v python)\" ${CLAUDE_PLUGIN_ROOT}/hooks/launch_dashboard.py"
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$(command -v python3 || command -v python)\" ${CLAUDE_PLUGIN_ROOT}/hooks/record_skill.py"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$(command -v python3 || command -v python)\" ${CLAUDE_PLUGIN_ROOT}/hooks/record_subagent.py"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$(command -v python3 || command -v python)\" ${CLAUDE_PLUGIN_ROOT}/hooks/record_skill.py"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$(command -v python3 || command -v python)\" ${CLAUDE_PLUGIN_ROOT}/hooks/launch_dashboard.py"
          }
        ]
      }
    ],
    "UserPromptExpansion": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$(command -v python3 || command -v python)\" ${CLAUDE_PLUGIN_ROOT}/hooks/record_skill.py"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$(command -v python3 || command -v python)\" ${CLAUDE_PLUGIN_ROOT}/hooks/launch_dashboard.py"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$(command -v python3 || command -v python)\" ${CLAUDE_PLUGIN_ROOT}/hooks/record_subagent.py"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$(command -v python3 || command -v python)\" ${CLAUDE_PLUGIN_ROOT}/hooks/record_subagent.py"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$(command -v python3 || command -v python)\" ${CLAUDE_PLUGIN_ROOT}/hooks/record_session.py"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$(command -v python3 || command -v python)\" ${CLAUDE_PLUGIN_ROOT}/hooks/launch_dashboard.py"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$(command -v python3 || command -v python)\" ${CLAUDE_PLUGIN_ROOT}/hooks/record_session.py"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$(command -v python3 || command -v python)\" ${CLAUDE_PLUGIN_ROOT}/hooks/record_session.py"
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$(command -v python3 || command -v python)\" ${CLAUDE_PLUGIN_ROOT}/hooks/record_session.py"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$(command -v python3 || command -v python)\" ${CLAUDE_PLUGIN_ROOT}/hooks/record_session.py"
          }
        ]
      }
    ],
    "InstructionsLoaded": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$(command -v python3 || command -v python)\" ${CLAUDE_PLUGIN_ROOT}/hooks/record_session.py"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$(command -v python3 || command -v python)\" ${CLAUDE_PLUGIN_ROOT}/hooks/verify_session.py"
          }
        ]
      }
    ]
  }
}

